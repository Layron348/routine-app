BOT_TOKEN=your_telegram_bot_token_here
MINI_APP_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
DATABASE_URL=sqlite:///./routine.db
CORS_ORIGINS=http://localhost:5173
VITE_API_BASE_URL=/api

# Required: generate a strong random key for JWT signing.
# Example generation (PowerShell): [Convert]::ToBase64String((1..48 | ForEach-Object { Get-Random -Max 256 }) -as [byte[]])
# Example generation (bash): openssl rand -base64 64
SECRET_KEY=change-this-to-a-secure-random-key-at-least-32-bytes-long
